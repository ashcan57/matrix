<?xml version="1.0" encoding="UTF-8"?>
<addon id="repository.matrix"
       name="Matrix Repository"
       version="1.0.0"
       provider-name="ashcan57">

    <extension point="xbmc.addon.repository"
               name="Matrix Repo">

        <info>https://raw.githubusercontent.com/ashcan57/matrix/main/addons.xml</info>
        <checksum>https://raw.githubusercontent.com/ashcan57/matrix/main/addons.xml.md5</checksum>
        <datadir>https://raw.githubusercontent.com/ashcan57/matrix/main/zip/</datadir>

    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Matrix Add-on Repository</summary>
        <description>Contains Matrix add-ons and the wizard. Install this repo to access the add-ons in Kodi.</description>
        <platform>all</platform>
    </extension>

</addon>
