<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.program.matrixwizard"
       name="Matrix Wizard"
       version="1.0.0"
       provider-name="ashcan57">

    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>

    <extension point="xbmc.python.pluginsource" library="wizard.py" />

    <extension point="xbmc.addon.metadata">
        <summary>Matrix Wizard Installer</summary>
        <description>Wizard that downloads the Encore build from Dropbox and installs it into Kodi (unzip).</description>
        <platform>all</platform>
    </extension>

</addon>
